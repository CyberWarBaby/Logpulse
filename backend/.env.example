# ─────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# ─── DATABASE ─────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
#
# Common local setups — try one of these:
#   postgresql://postgres:postgres@localhost:5432/logpulse?schema=public
#   postgresql://postgres:password@localhost:5432/logpulse?schema=public
#   postgresql://YOUR_UNIX_USERNAME@localhost:5432/logpulse?schema=public
#
# To find your credentials:
#   sudo -u postgres psql                   (Ubuntu/Debian — enter as postgres superuser)
#   psql -U postgres                        (if postgres user has no password)
#
# To create the DB:
#   createdb logpulse
#   OR: psql -U postgres -c "CREATE DATABASE logpulse;"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logpulse?schema=public"

# ─── REDIS ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-32-char-secret-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
INGEST_RATE_LIMIT_MAX=1000

# ─── SEED (only used by: npm run seed) ────────────────────────
# Set these before running the seed script
SEED_ORG_NAME=My Organization
SEED_ADMIN_EMAIL=admin@example.com
SEED_MEMBER_EMAIL=member@example.com
SEED_ADMIN_PASSWORD=   # <-- set a strong password here
